# Gaidance API keys — 실제 값은 .env 에 넣으세요 (.env 는 git 제외됨)

# ── 고용24(워크넷) OpenAPI authKey ─ endpoint: openapi.work.go.kr ──
# 직업정보 API (직업 설명: 하는 일/연봉/전망) — 경로 A 백본
WORK24_OCCUPATION_KEY=
# 직무정보 API (직무 데이터) — 경로 A 백본
WORK24_JOBDUTY_KEY=
# 채용정보 API (개인가능: 공채속보/공채기업정보/채용행사) — 트랙1 대기업 수요 신호
WORK24_RECRUIT_KEY=

# ── 사람인 OAPI ──
# access-key — 시장 수요 메타(공고 본문 미제공)
SARAMIN_KEY=
